[submodule "third-party/git-aware-prompt"]
	path = third-party/git-aware-prompt
	url = https://github.com/jimeh/git-aware-prompt
[submodule "third-party/git"]
	path = third-party/git
	url = https://github.com/git/git
	shallow = true
[submodule "third-party/JetBrainsMono"]
	path = third-party/JetBrainsMono
	url = https://github.com/JetBrains/JetBrainsMono
	shallow = true
